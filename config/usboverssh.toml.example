# USBoverSSH Configuration File
# Location: ~/.config/usboverssh/config.toml

# ══════════════════════════════════════════════════════════════════════════════
# General Settings
# ══════════════════════════════════════════════════════════════════════════════
[general]
# Delay between reconnection attempts (seconds)
reconnect_delay = 5

# Maximum reconnection attempts (0 = unlimited)
max_reconnect_attempts = 0

# Connection timeout (seconds)
connection_timeout = 30

# Enable verbose output
verbose = false

# ══════════════════════════════════════════════════════════════════════════════
# SSH Settings
# ══════════════════════════════════════════════════════════════════════════════
[ssh]
# Default SSH port
default_port = xx

# Default SSH identity file (optional)
# identity_file = "~/.ssh/example_key"

# SSH config file path
# config_file = "~/.ssh/config_example"

# Enable SSH agent forwarding
agent_forwarding = true

# Keep-alive interval (seconds)
keepalive_interval = 30

# Strict host key checking
strict_host_key_checking = true

# ══════════════════════════════════════════════════════════════════════════════
# Logging Settings
# ══════════════════════════════════════════════════════════════════════════════
[logging]
# Log level: trace, debug, info, warn, error
level = "info"

# Log format: text, json
format = "text"

# Log file path (optional, logs to stderr if not set)
# file = "/path/to/usboverssh.log"

# Enable colored output
color = true

# ══════════════════════════════════════════════════════════════════════════════
# TUI Settings
# ══════════════════════════════════════════════════════════════════════════════
[tui]
# Device list refresh interval (milliseconds)
refresh_interval = 1000

# Enable mouse support
mouse = true

# Color theme: default, nord, gruvbox
theme = "default"

# Show device serial numbers
show_serial = true

# Show device speed
show_speed = true

# ══════════════════════════════════════════════════════════════════════════════
# Named Hosts
# Define hosts for quick access: usboverssh list myserver
# ══════════════════════════════════════════════════════════════════════════════

# Example: Remote server
[hosts.example_server]
hostname = "example.com"
port = xx
user = "username"
# identity_file = "/path/to/private/keyxxxx"
description = "My Example Server"

# Example: Another host
[hosts.example_workstation]
hostname = "xxx.xxx.xxx.xxx"
port = xx
user = "username"
description = "Example Workstation"

# Example: Local Host
[hosts.example_local]
hostname = "hostname.local"
port = xx
user = "username"
description = "Example Local Machine"

# ══════════════════════════════════════════════════════════════════════════════
# Auto-Attach Rules
# Automatically attach devices when they are connected
# ══════════════════════════════════════════════════════════════════════════════

# Example: Auto-attach webcams by vendor ID
[[auto_attach]]
name = "Example Webcam"
enabled = false
host = "example_server"
[auto_attach.filter]
vendor_id = 0xXXXX  # Replace with actual Vendor ID

# Example: Auto-attach specific device by VID:PID
[[auto_attach]]
name = "Example Device"
enabled = false
host = "example_workstation"
[auto_attach.filter]
vendor_id = 0xXXXX   
product_id = 0xXXXX
